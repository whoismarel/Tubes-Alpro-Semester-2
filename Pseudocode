// =================== SEARCHING & SORTING ===================

function cariPetugas(user: string, pass: string) -> integer
{ IS: Array dataPetugas terdefinisi
  FS: Mengembalikan indeks petugas jika cocok, atau -1 jika gagal (Sequential Search) }
kamus
    idx, i: integer
algoritma
    idx <- -1
    i <- 0
    while (i < nPetugas) and (idx == -1) do
        if dataPetugas[i].username == user and dataPetugas[i].password == pass then
            idx <- i
        endif
        i <- i + 1
    endwhile
    -> idx
endfunction

function binarySearchKendaraan(plat: string) -> integer
{ IS: Array dataKendaraan terurut menaik berdasarkan plat nomor
  FS: Mengembalikan indeks kendaraan jika ditemukan, atau -1 jika gagal }
kamus
    kiri, kanan, tengah, idx: integer
algoritma
    kiri <- 0
    kanan <- nKendaraan - 1
    idx <- -1

    while (kiri <= kanan) and (idx == -1) do
        tengah <- (kiri + kanan) div 2
        if dataKendaraan[tengah].platNomor == plat then
            idx <- tengah
        else if dataKendaraan[tengah].platNomor < plat then
            kiri <- tengah + 1
        else
            kanan <- tengah - 1
        endif
    endwhile
    -> idx
endfunction

procedure sortPlatAsc()
{ Mengurutkan kendaraan menaik berdasarkan Plat Nomor (Selection Sort) }
kamus
    i, j, minIdx: integer
    temp: Kendaraan
algoritma
    for i <- 0 to nKendaraan - 2 do
        minIdx <- i
        for j <- i + 1 to nKendaraan - 1 do
            if dataKendaraan[j].platNomor < dataKendaraan[minIdx].platNomor then
                minIdx <- j
            endif
        endfor
        temp <- dataKendaraan[i]
        dataKendaraan[i] <- dataKendaraan[minIdx]
        dataKendaraan[minIdx] <- temp
    endfor
endprocedure

procedure sortBiayaAsc()
{ Mengurutkan kendaraan menaik berdasarkan Biaya (Selection Sort) }
kamus
    i, j, minIdx: integer
    temp: Kendaraan
algoritma
    for i <- 0 to nKendaraan - 2 do
        minIdx <- i
        for j <- i + 1 to nKendaraan - 1 do
            if dataKendaraan[j].biaya < dataKendaraan[minIdx].biaya then
                minIdx <- j
            endif
        endfor
        temp <- dataKendaraan[i]
        dataKendaraan[i] <- dataKendaraan[minIdx]
        dataKendaraan[minIdx] <- temp
    endfor
endprocedure

procedure sortBiayaDesc()
{ Mengurutkan kendaraan menurun berdasarkan Biaya (Insertion Sort) }
kamus
    i, j: integer
    key: Kendaraan
algoritma
    for i <- 1 to nKendaraan - 1 do
        key <- dataKendaraan[i]
        j <- i - 1
        while j >= 0 and dataKendaraan[j].biaya < key.biaya do
            dataKendaraan[j+1] <- dataKendaraan[j]
            j <- j - 1
        endwhile
        dataKendaraan[j+1] <- key
    endfor
endprocedure

// =================== CRUD PETUGAS (ADMIN) ===================

procedure tambahPetugas()
kamus
    user: string
    i: integer
algoritma
    if nPetugas >= NMAX then
        output("Data petugas penuh.")
    else
        output("Username : ")
        input(user)
        
        i <- 0
        while i < nPetugas do
            if dataPetugas[i].username == user then
                output("Username sudah digunakan.")
                return
            endif
            i <- i + 1
        endwhile

        dataPetugas[nPetugas].username <- user
        output("Password : ")
        input(dataPetugas[nPetugas].password)
        nPetugas <- nPetugas + 1
        output("Petugas berhasil ditambahkan.")
    endif
endprocedure

procedure editPetugas()
kamus
    user, pilihanEdit: string
    i: integer
algoritma
    output("Masukkan Username Petugas : ")
    input(user)

    i <- 0
    while i < nPetugas do
        if dataPetugas[i].username == user then
            output("1. Edit Username")
            output("2. Edit Password")
            input(pilihanEdit)

            if pilihanEdit == "1" then
                input(dataPetugas[i].username)
            else if pilihanEdit == "2" then
                input(dataPetugas[i].password)
            endif
            return
        endif
        i <- i + 1
    endwhile
    output("Petugas tidak ditemukan.")
endprocedure

procedure hapusPetugas()
kamus
    user: string
    i, j: integer
algoritma
    output("Masukkan Username Petugas : ")
    input(user)

    i <- 0
    while i < nPetugas do
        if dataPetugas[i].username == user then
            j <- i
            while j < nPetugas - 1 do
                dataPetugas[j] <- dataPetugas[j+1]
                j <- j + 1
            endwhile
            nPetugas <- nPetugas - 1
            output("Petugas berhasil dihapus.")
            return
        endif
        i <- i + 1
    endwhile
    output("Petugas tidak ditemukan.")
endprocedure

procedure lihatPetugas()
kamus
    i: integer
algoritma
    cetakJudulMenu("DAFTAR PETUGAS")
    for i <- 0 to nPetugas - 1 do
        output("Username : ", dataPetugas[i].username)
        output("Password : ", dataPetugas[i].password)
        cetakGaris()
    endfor
endprocedure

// =================== MANAJEMEN KENDARAAN ===================

procedure kendaraanMasuk()
kamus
    plat, jenis: string
algoritma
    if nKendaraan < NMAX then
        input(plat)
        input(jenis)
        dataKendaraan[nKendaraan].platNomor <- plat
        dataKendaraan[nKendaraan].jenis <- jenis
        dataKendaraan[nKendaraan].status <- "PARKIR"
        dataKendaraan[nKendaraan].biaya <- 0
        nKendaraan <- nKendaraan + 1
        output("Kendaraan berhasil masuk.")
    else
        output("Kapasitas parkir penuh!")
    endif
endprocedure

procedure kendaraanKeluar()
kamus
    plat: string
    idx, durasi: integer
algoritma
    input(plat)
    sortPlatAsc()
    idx <- binarySearchKendaraan(plat)

    if idx != -1 and dataKendaraan[idx].status == "PARKIR" then
        input(durasi)
        if durasi <= 0 then
            durasi <- 1
        endif

        dataKendaraan[idx].durasi <- durasi
        dataKendaraan[idx].status <- "KELUAR"

        if dataKendaraan[idx].jenis == "Mobil" then
            dataKendaraan[idx].biaya <- 5000 + (durasi * 2000)
        else
            dataKendaraan[idx].biaya <- 2000 + (durasi * 1000)
        endif
        output("Rincian Pembayaran...")
    else
        output("Kendaraan tidak ditemukan atau sudah keluar.")
    endif
endprocedure

procedure cetakLaporanPendapatan()
kamus
    pilih, urut: string
    i: integer
algoritma
    output("FILTER: 1. Semua, 2. Mobil, 3. Motor")
    input(pilih)
    
    output("URUTKAN: 1. Descending, 2. Ascending")
    input(urut)

    if urut == "1" then
        sortBiayaDesc()
    else if urut == "2" then
        sortBiayaAsc()
    else
        return
    endif

    output("PLAT | JENIS | DURASI | BIAYA")
    for i <- 0 to nKendaraan - 1 do
        if pilih == "1" or 
          (pilih == "2" and dataKendaraan[i].jenis == "Mobil") or 
          (pilih == "3" and dataKendaraan[i].jenis == "Motor") then
            output(dataKendaraan[i].platNomor, dataKendaraan[i].jenis, dataKendaraan[i].durasi, dataKendaraan[i].biaya)
        endif
    endfor
endprocedure

