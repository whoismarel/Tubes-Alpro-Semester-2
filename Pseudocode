Constant MAX: integer = 100

type Petugas : <
    username : string,
    password : string,
    nama     : string
>

type Kendaraan : <
    platNomor : string,
    jenis     : string,
    durasi    : integer,
    biaya     : integer,
    status    : string
>

type ArrPetugas array [0..MAX-1] of Petugas
type ArrKendaraan array [0..MAX-1] of Kendaraan

// Deklarasi Variabel Global
dataPetugas   : ArrPetugas
nPetugas      : integer
dataKendaraan : ArrKendaraan
nKendaraan    : integer

